generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model Form {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String
  description String?
  fileKey     String   // storage key (R2 later). For now can point to local file name.
  mimeType    String   @default("application/pdf")
  sizeBytes   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}